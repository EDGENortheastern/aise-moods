# Copy this file to .env and fill in real values. Do NOT commit .env.

# MongoDB Atlas connection string (Cluster -> Connect -> Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/aise_moods?appName=Cluster0

# Database name
DATABASE_NAME=aise_moods

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Frontend origin (used for CORS)
FRONTEND_URL=https://your-frontend.vercel.app
